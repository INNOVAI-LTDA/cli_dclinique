# Python bytecode
__pycache__/
*.pyc
*.pyo

# Streamlit runtime secrets (configured via Streamlit Cloud UI)
.streamlit/secrets.toml

# Local env files
.env
.env.local

# Anything marked as private client data — guard against accidental commit
data/private/

# Real patient PDFs (input for future parser work, never versioned)
# Contains PII by design; processing happens in throwaway worktrees only.
data/pacientes_e_planos/

# New CSVs dropped by the importer (Agendamentos / Relatorio de frequencia)
# Carry real patient PII from SupportHealth; dev must place files locally
# before running `scripts/validate_end_to_end.py --data=csv`.
data/new/

# Hypothesis / pytest caches
.hypothesis/
.pytest_cache/

# Test run logs (regenerated by `python scripts/run_scrum_tests.py` and
# `python scripts/validate_neon.py`; not part of the repo source)
data/test_logs/

# Development logs from Caminho B (phases 0-7) — pytest output captured by
# `pwsh scripts/run_core_tests.ps1` and one-off debug PowerShell scripts.
# Regenerable by re-running the suite; not part of the repo source.
logs/*.log
logs/*.json
logs/*.ps1
