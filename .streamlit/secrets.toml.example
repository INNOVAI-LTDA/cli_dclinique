# Secrets injetados pelo Streamlit Cloud (Settings → Secrets).
# O arquivo real `.streamlit/secrets.toml` é **gitignored**; este template
# é commitado apenas para documentar o formato esperado.
#
# No código, leia via `st.secrets["chave"]`. Não use `os.environ` para
# secrets definidos aqui — o Streamlit Cloud só os expõe via `st.secrets`.

# Backend ativo em PRD — Postgres (Neon Serverless).
# A DSN vem do painel Neon: Connection string → pooler ou direct.
# `get_engine()` em `src/data_layer/connection.py` le esta chave
# via `st.secrets["postgres"]["dsn"]` e cacheia o engine.
#
# IMPORTANTE: NAO inclua `&channel_binding=require` quando a DSN
# aponta para o endpoint `*-pooler` (PgBouncer em transaction mode).
# O pooler NAO retransmite channel binding; o handshake SSL inicial
# passa mas o pooler fecha a conexao no meio do primeiro query com
# "SSL connection has been closed unexpectedly" (reproduzido em PRD
# no Streamlit Cloud em 2026-06-21). `sslmode=require` sozinho
# mantem a conexao criptografada sem channel binding.
[postgres]
dsn = "postgresql://user:pass@ep-xxx-pooler.<region>.aws.neon.tech/dclinique?sslmode=require"

# As secoes abaixo permanecem comentadas — Supabase nao e' mais
# o backend alvo, e as integracoes (WhatsApp, etc.) estao fora do
# escopo desta casca conforme `CLAUDE.md`.

# [supabase]
# url = "https://<project>.supabase.co"
# anon_key = "<anon-key>"

# [integrations]
# whatsapp_token = "<token>"
